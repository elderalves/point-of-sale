# TestRail instance URL (include https://)
TESTRAIL_HOST=https://your-company.testrail.io

# TestRail account used by trcli
TESTRAIL_USERNAME=you@example.com

# Use either an API key or password
TESTRAIL_API_KEY=your_api_key_here
# TESTRAIL_PASSWORD=your_password_here

# Project name exactly as it appears in TestRail
TESTRAIL_PROJECT=Point of Sale

# Optional upload settings
TESTRAIL_RUN_NAME=POS Playwright Automated Test Run
# TESTRAIL_JUNIT_PATH=test-results/junit-report.xml
# TESTRAIL_CASE_FIELDS=custom_automation_type:5
# TESTRAIL_RESULT_FIELDS=version:1.0.0
