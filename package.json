{
  "name": "pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service serve --open",
    "serve:test": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service serve --host 127.0.0.1 --port 4173",
    "build": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build",
    "lint": "vue-cli-service lint",
    "test:e2e": "playwright test",
    "test:e2e:allure": "node scripts/run-e2e-allure.js",
    "test:e2e:allure:pdf": "node scripts/build-allure-stakeholder-pdf.js",
    "test:e2e:report": "node scripts/run-e2e-report.js",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:testrail": "node scripts/run-e2e-with-testrail.js",
    "testrail:upload": "node scripts/upload-testrail-junit.js"
  },
  "dependencies": {
    "gsap": "^1.20.4",
    "sass": "^1.83.4",
    "sass-loader": "^10.5.2",
    "vue": "^2.5.13",
    "vuex": "^3.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vue/cli-plugin-babel": "^3.0.0-beta.6",
    "@vue/cli-plugin-eslint": "^3.0.0-beta.6",
    "@vue/cli-service": "^3.0.0-beta.6",
    "allure": "^3.0.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.6.1",
    "eslint": "^4.19.1",
    "eslint-config-standard": "^11.0.0",
    "eslint-plugin-import": "^2.9.0",
    "eslint-plugin-node": "^6.0.1",
    "eslint-plugin-promise": "^3.7.0",
    "eslint-plugin-standard": "^3.0.1",
    "fast-xml-parser": "^4.5.3",
    "vue-template-compiler": "^2.5.13"
  },
  "babel": {
    "presets": [
      "@vue/app"
    ]
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ]
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ]
}
